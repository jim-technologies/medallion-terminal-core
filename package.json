{
  "name": "medallion-terminal-core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/medallion-terminal-core.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/medallion-terminal-core.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "proto"
  ],
  "scripts": {
    "dev": "vite",
    "lint": "tsc --noEmit && buf lint",
    "test": "vitest run",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "ci": "pnpm install --frozen-lockfile && pnpm lint && pnpm test && pnpm build && pnpm build:lib && pnpm build:storybook"
  },
  "peerDependencies": {
    "lightweight-charts": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0"
  },
  "dependencies": {
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@storybook/react": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "esbuild": "^0.27.4",
    "storybook": "^10.2.19",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
